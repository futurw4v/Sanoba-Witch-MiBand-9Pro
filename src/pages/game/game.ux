<!-- 此ux有点职责过重了，后期打算模块化 -->
<template>
  <div class="page" @click="handleScreenClick" @swipe="handleSwipe" @longpress="handleLongPress">
    <image class="bg-image" src="{{ '/common/bg/' + currentBg + '.jpg' }}"></image>

    <div class="ui-layer">
      <!-- 对话框部分（说话人与打字机） -->
      <div class="speaker-box" if="{{ currentSpeaker }}">
        <text class="speaker-text">{{ currentSpeaker }}</text>
      </div>

      <div class="dialogue-box" if="{{ !isLoading }}">
        <scroll scroll-y="true" class="scroll-view" id="dialogueScroll">
          <text
            class="typewriter-text"
            style="font-size: {{ settings.textSize }}px; line-height: {{ settings.textSize * 1.3 }}px;"
          >
            {{ displayText }}
          </text>
        </scroll>
      </div>
    </div>

    <!-- 选项按钮 -->
    <div class="options-overlay" if="{{ showOptions }}">
      <div class="options-container">
        <div
          for="{{ (index, item) in currentOptions }}"
          class="option-button"
          @click="handleOptionClick(item[1], item[2])"
        >
          <text class="option-text">{{ item[0] }}</text>
        </div>
      </div>
    </div>

    <!-- 侧滑/长按菜单部分 -->
    <div class="menu-overlay" if="{{ showSwipeMenu }}">
      <!-- 暗话背景 -->
      <image
        class="bg-image"
        style="opacity: 0.4"
        src="{{ '/common/bg/' + currentBg + '.jpg' }}"
      ></image>

      <!-- 容器与按钮 -->
      <div class="menu-container" @click="stopClick">
        <text class="menu-time">{{ currentTime }}</text>

        <text class="menu-title">菜单</text>

        <div class="menu-grid">
          <div class="menu-btn" @click="saveGame">
            <text class="btn-text">保存进度</text>
          </div>
          <div class="menu-btn" @click="routeLoad">
            <text class="btn-text">读取进度</text>
          </div>
          <div class="menu-btn" @click="skipToOptions">
            <text class="btn-text">跳过到下一个选项</text>
          </div>
          <div class="menu-btn" @click="returnToHome">
            <text class="btn-text">返回主页</text>
          </div>
          <div class="menu-btn close-btn" @click="closeMenu">
            <text class="btn-text">返回游戏</text>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import {DEBUG, SCN_TYPE, SCN_LIST, SETTINGS_KEY} from "../../common/constants.js"

import storage from "@system.storage"
import file from "@system.file"
import router from "@system.router"
import prompt from "@system.prompt"

export default {
  private: {
    // 剧本有关
    scriptData: [],
    currentScnId: "001",
    currentLineIndex: 0,
    currentCharIndex: 0,

    // 游戏有关
    displayText: "",
    fullText: "",
    currentSpeaker: "",
    currentBg: "空_青空",
    currentChapterName: "",
    currentCharacters: [],
    gameFlags: {},

    // UI有关
    timer: null,
    isTextComplete: false,
    showSwipeMenu: false,
    currentTime: "00:00",

    // 选项有关
    currentOptions: [],
    showOptions: false,

    // 状态与设置
    isLoading: true,
    isSkipping: false,
    settings: {
      textSpeed: 40,
      textSize: 20
    }
  },

  onInit() {
    // 读取系统设置（音量、文字速度等）
    storage.get({
      key: SETTINGS_KEY,
      success: (data) => {
        if (data) {
          try {
            const parsed = JSON.parse(data)
            this.settings.textSpeed = parsed.textSpeed
            this.settings.textSize = parsed.textSize
            if (DEBUG) console.log("[Game/System] 设置加载成功")
          } catch (e) {
            if (DEBUG) console.error("[Game/System] 解析设置失败")
          }
        }
      }
    })
  },

  // 监听页面显示，尝试从全局状态恢复进度
  onShow() {
    const stateToLoad = this.$app.$def.globalGameState

    if (stateToLoad) {
      if (DEBUG) console.log("[Game/IO] 恢复存档状态:", stateToLoad)

      // 读取存档内容
      const targetScnId = stateToLoad.currentScnId || "001"
      const targetIndex = parseInt(stateToLoad.currentLineIndex, 10) || 0
      const targetBg = stateToLoad.currentBg
      const targetChapterName = stateToLoad.currentChapterName
      const targetGameFlags = stateToLoad.gameFlags

      if (targetChapterName) {
        this.currentChapterName = targetChapterName
      }

      if (targetGameFlags) {
        this.gameFlags = targetGameFlags
      }

      // 清除全局变量防止重复触发
      this.$app.$def.globalGameState = null

      if (this.timer) clearTimeout(this.timer)

      // 加载剧本并跳转到对应行
      this.loadScenario(targetScnId, targetIndex, targetBg)
    } else {
      // 如果没有存档状态，且当前没在播放剧本，则加载默认进度
      if (!this.scriptData || this.scriptData.length === 0) {
        this.loadScenario(this.currentScnId, this.currentLineIndex)
      }
    }
  },

  // 跳过到下一个选项
  skipUntilSelect() {
    // 如果还未进入下一条剧本，直接返回
    if (!this.scriptData || this.scriptData.length === 0) return

    this.isSkipping = true

    // 抓取文本
    let lastDialogueNode = null

    while (this.currentLineIndex < this.scriptData.length) {
      const node = this.scriptData[this.currentLineIndex]
      const type = node[0]

      if (type === SCN_TYPE.SELECT) {
        // 停止前，同步最后一句对话内容
        if (lastDialogueNode) {
          this.currentSpeaker = lastDialogueNode[1] || ""
          this.fullText = lastDialogueNode[2] || ""
          this.displayText = this.fullText
          this.isTextComplete = true
        }

        this.isSkipping = false
        this.currentOptions = node[1]
        this.showOptions = true

        // 渲染文本为最后一行对话（可选，让画面不至于太突兀）
        this.isTextComplete = true
        if (DEBUG) console.log("[Game/Engine] 快进停止于选项")
        return // 退出函数，等待玩家操作
      }

      // 抓取文本
      if (type === SCN_TYPE.DIALOGUE) {
        lastDialogueNode = node
      }

      // 更新背景防止错乱
      if (type === SCN_TYPE.BG) {
        const bg = node[1]
        this.currentBg = bg
        if (DEBUG) console.log("[Game/Engine] 背景更新：" + bg)
      }

      // 更新章节名称
      if (type === SCN_TYPE.TITLE) {
        this.currentChapterName = node[1]
      }

      // 继续下一行
      this.currentLineIndex++
    }

    // 如果循环结束还没找到选项，说明本章节结束了
    if (this.currentLineIndex >= this.scriptData.length) {
      this.goToNextScenario()
    }
  },

  getNextScn(currentId) {
    if (currentId === "020_nene") return SCN_LIST.nene[0]
    if (currentId === "020_meguru") return SCN_LIST.meguru[0]
    if (currentId === "020_tsumugi") return SCN_LIST.tsumugi[0]
    if (currentId === "020_akogare") return SCN_LIST.akogare[0]

    // 查找共通线
    const commonList = SCN_LIST.common
    const commonIdx = commonList.findIndex((i) => i.id === currentId)

    if (commonIdx !== -1) {
      // 核心分歧点：共通线 019 结束时
      if (currentId === "019") {
        const route = this.determineRoute() // 获取得分最高的角色ID

        switch (route) {
          case "nene":
            return commonList.find((i) => i.id === "020_nene")
          case "meguru":
            return commonList.find((i) => i.id === "020_meguru")
          case "tsumugi":
            return commonList.find((i) => i.id === "020_tsumugi")
          case "akogare":
            return commonList.find((i) => i.id === "020_akogare")
          case "wakana":
            return SCN_LIST.wakana[0] // 和奏直接进 500
          default:
            return commonList[commonIdx + 1]
        }
      }

      // 普通共通线顺序推进
      return commonList[commonIdx + 1] || null
    }

    // 遍历所有个人线，查找当前 ID 的下一章
    const routes = ["nene", "meguru", "tsumugi", "akogare", "wakana"]
    for (const route of routes) {
      const list = SCN_LIST[route]
      if (!list) continue
      const index = list.findIndex((i) => i.id === currentId)
      if (index !== -1) {
        return list[index + 1] || null // 没有下一章则 null
      }
    }

    // 完全找不到，返回 null
    return null
  },

  async loadScenario(id, startIndex = 0, savedBg = null) {
    this.isLoading = true

    if (this.timer) clearTimeout(this.timer)

    try {
      const fileName = this.getPathById(id)
      if (!fileName) throw new Error(`未找到ID: ${id}`)

      // 调用上面的读取函数
      const result = await this.readJsonFile(fileName)

      // 处理数据格式
      this.scriptData = Array.isArray(result) ? result : result.content || []

      this.currentScnId = id
      this.currentLineIndex = parseInt(startIndex, 10)

      if (savedBg) {
        if (DEBUG) console.log("[Game/IO] 应用存档背景: " + savedBg)
        this.currentBg = savedBg
      }

      this.isLoading = false

      if (DEBUG) console.log(`[Game/IO] ${id} 加载成功，startIndex: ${startIndex}`)

      this.showLine()
    } catch (error) {
      this.isLoading = false
      this.displayText = "错误: " + error.message
      if (DEBUG) console.error("[Game/IO] 场景加载失败: " + error.message)
    }
  },

  // 封装 file.readText 为 Promise
  readJsonFile(fileName) {
    return new Promise((resolve, reject) => {
      file.readText({
        uri: `/common/scn/${fileName}`,
        success: (data) => {
          try {
            const jsonData = JSON.parse(data.text)
            resolve(jsonData)
          } catch (e) {
            reject(new Error(`JSON解析失败: ${e.message}`))
          }
        },
        fail: (error) => {
          reject(new Error(`文件读取失败: ${error.code}`))
        }
      })
    })
  },

  goToNextScenario() {
    const next = this.getNextScn(this.currentScnId, this.userSelectedRoute || "common")

    if (next) {
      if (DEBUG) console.log(`[Game/Engine] 准备进入下一章节: ${next.name}`)
      this.currentScnId = next.id
      this.loadScenario(next.id)
    } else {
      if (DEBUG) console.warn("[Game/Engine] 未找到后续章节，结束")
      prompt.showToast({message: "游戏结束"})
    }
  },

  showLine() {
    if (!this.scriptData || this.scriptData.length === 0) {
      if (DEBUG) console.warn("[Game/Engine] 等待剧本加载...")
      return
    }

    // 跨章节连续跳过
    if (this.isSkipping) {
      this.skipUntilSelect()
      return
    }

    const node = this.scriptData[this.currentLineIndex]
    if (!node) {
      this.goToNextScenario()
      return
    }

    const type = node[0]

    switch (type) {
      case SCN_TYPE.NODE:
        // 标签，记录日志并自动跳到下一行
        if (DEBUG) console.log("[Game/Engine] 进入节点: " + node[1])
        this.currentLineIndex++
        this.showLine()
        break

      case SCN_TYPE.BG:
        // 切换背景并跳到下一行
        this.currentBg = node[1]
        this.currentLineIndex++
        this.showLine()
        break

      case SCN_TYPE.DIALOGUE:
        // 对话更新 [2, "说话人", "内容", [立绘列表（可选）]]
        this.currentSpeaker = node[1] || ""
        this.fullText = node[2] || ""

        // 立绘更新 (数组长度大于3说明有立绘数据)
        // TODO: 立绘实现
        //if (node.length > 3) {
        //this.currentCharacters = node[3];
        //}

        this.displayText = ""
        this.isTextComplete = false
        this.currentCharIndex = 0
        this.showTypeWriterEffect()
        break

      case SCN_TYPE.SELECT:
        // 选项：[3, [["文字", "跳转", "表达式"]]]
        this.currentOptions = node[1]
        this.showOptions = true
        break

      case SCN_TYPE.TITLE:
        // 章节标题 [4, "章节标题"]
        this.currentChapterName = node[1]

        if (DEBUG) {
          console.log("[Game/Engine] 读取到新章节名称: " + this.currentChapterName)

          prompt.showToast({
            message: this.currentChapterName,
            duration: 2000
          })
        }

        this.currentLineIndex++
        this.showLine()
        break

      case SCN_TYPE.JUMP:
        // 跳转 [5, "label_name"]
        const targetLabel = node[1]
        const jumpIndex = this.scriptData.findIndex(
          (item) => item[0] === SCN_TYPE.NODE && item[1] === targetLabel
        )

        if (jumpIndex !== -1) {
          this.currentLineIndex = jumpIndex
          if (DEBUG) console.info("[Game/Engine] 跳转至节点：" + targetLabel)
          this.showLine()
        } else {
          if (DEBUG) console.error("[Game/Engine] 跳转目标未找到：" + targetLabel)
          this.currentLineIndex++
          this.showLine()
        }
        break
    }
  },

  showTypeWriterEffect() {
    if (this.timer) clearTimeout(this.timer)

    if (this.currentCharIndex === 0) {
      const scroll = this.$element("dialogueScroll")
      if (scroll) {
        scroll.scrollTo({top: 0, behavior: "instant"})
      }
    }

    if (this.currentCharIndex < this.fullText.length) {
      this.displayText += this.fullText.charAt(this.currentCharIndex)
      this.currentCharIndex++

      this.timer = setTimeout(() => {
        this.showTypeWriterEffect()
      }, this.settings.textSpeed)

      if (this.currentCharIndex % 5 === 0 && this.displayText.length > 20) {
        const scroll = this.$element("dialogueScroll")
        if (scroll) {
          scroll.scrollTo({top: 9999, behavior: "instant"})
        }
      }
    } else {
      this.finishText()
    }
  },

  /* 
      剧本有关（解析剧本等）
  */
  // 解析表达式
  runExp(expStr) {
    if (!expStr) return
    if (DEBUG) console.log("[Game/System] 执行表达式: " + expStr)

    // 按照逗号拆分多条指令 (如 "f.sel_flag=0, f.wak_flag++")
    const parts = expStr.split(",")

    parts.forEach((part) => {
      let cmd = part.trim()
      try {
        if (cmd.includes("++")) {
          // 处理自增: f.wak_flag ++
          const varName = cmd.replace("f.", "").replace("++", "").trim()
          this.gameFlags[varName] = (this.gameFlags[varName] || 0) + 1
        } else if (cmd.includes("--")) {
          // 处理自减: f.wak_flag -- (其实不知道有没有这种 保险起见还是写上去了)
          const varName = cmd.replace("f.", "").replace("--", "").trim()
          this.gameFlags[varName] = (this.gameFlags[varName] || 0) - 1
        } else if (cmd.includes("=")) {
          // 处理赋值: f.sel_flag = 1
          let [varName, val] = cmd.split("=")
          varName = varName.replace("f.", "").trim()
          val = val.trim()

          // 尝试转数字，转不了则存字符串
          const numVal = parseInt(val)
          this.gameFlags[varName] = isNaN(numVal) ? val : numVal
        }
      } catch (e) {
        console.error("[Game/System] Exp解析出错: " + cmd + " 错误信息: " + e.message)
      }
    })

    if (DEBUG) console.log("[Game/System] 同步后变量库: ", JSON.stringify(this.gameFlags))
  },

  // 通过gameFlag确定进入哪条线
  determineRoute() {
    const flags = this.gameFlags
    const flagScores = [
      {id: "nene", score: flags.nen_flag || 0},
      {id: "meguru", score: flags.meg_flag || 0},
      {id: "tsumugi", score: flags.tsu_flag || 0},
      {id: "akogare", score: flags.tou_flag || 0},
      {id: "wakana", score: flags.wak_flag || 0}
    ]

    // 按分数从高到低排序
    flagScores.sort((a, b) => b.score - a.score)

    // 返回分数最高的角色ID，如果最高分是0，就是单身
    if (flagScores[0].score === 0) {
      if (DEBUG) console.log("[Game/Engine] 好感度均为0，单身")
      return null
    }

    if (DEBUG) console.log(`[Game/Engine] 进入 ${flagScores[0].id} 线`)
    return flagScores[0].id
  },

  // 根据ID获取剧本路径
  getPathById(id) {
    for (const category of Object.values(SCN_LIST)) {
      const scene = category.find((item) => item.id === id)
      if (scene) return scene.path
    }
    return undefined
  },

  // 跳过章节
  skipToOptions() {
    this.closeMenu()
    this.skipUntilSelect()
  },

  finishText() {
    clearTimeout(this.timer)
    this.displayText = this.fullText
    this.isTextComplete = true
  },

  // 保存进度
  saveGame() {
    // 构造当前游戏状态
    const currentState = {
      currentScnId: this.currentScnId,
      currentLineIndex: this.currentLineIndex,
      currentBg: this.currentBg,
      currentSpeaker: this.currentSpeaker,
      currentChapterName: this.currentChapterName,
      gameFlags: this.gameFlags,
      fullText: this.fullText
    }

    this.closeMenu()

    // 跳转到 data 页面，并把传入当前状态
    router.push({
      uri: "pages/data",
      params: {currentState: currentState}
    })
  },

  /*  
      UI相关（点击/侧滑事件等）  
  */
  handleScreenClick() {
    if (this.showSwipeMenu || this.isLoading || this.showOptions) return

    if (this.isSkipping) {
      // 快进时，遇到选项已经暂停，如果用户再次点击（其实选项已弹出不会走到这），
      // 但以防万一,如果不在选项状态则继续快进
      if (!this.showOptions) {
        this.skipUntilSelect()
      }
      return
    }

    if (!this.isTextComplete) {
      this.finishText()
    } else {
      if (this.currentLineIndex < this.scriptData.length - 1) {
        this.currentLineIndex++
        this.showLine()
      } else {
        if (DEBUG) console.info("[Game/Engine] 当前章节结束，尝试进入下一章")
        this.goToNextScenario()
      }
    }
  },

  handleOptionClick(targetLabel, exp) {
    this.showOptions = false

    if (exp) {
      this.runExp(exp)
    }

    const targetIndex = this.scriptData.findIndex(
      (item) => item[0] === SCN_TYPE.NODE && item[1] === targetLabel
    )

    if (targetIndex !== -1) {
      this.currentLineIndex = targetIndex
      // 如果之前是快进模式，选项选择后继续快进
      if (this.isSkipping) {
        this.skipUntilSelect()
      } else {
        this.showLine()
      }
    } else {
      if (DEBUG) console.error("[Game/Engine] 未找到选项跳转标签: " + targetLabel)
      prompt.showToast({message: `未找到标签: ${targetLabel}`})
      this.showOptions = true
    }
  },

  closeMenu(event) {
    // 阻止事件冒泡
    if (event && event.stopPropagation) {
      event.stopPropagation()
    }

    this.showSwipeMenu = false
  },

  // 跳转到存档页
  routeLoad() {
    router.push({
      uri: "pages/data"
    })
  },

  // 阻止点击穿透，防止在侧滑时触发下一句
  stopClick(event) {
    // 拦截容器内的所有点击，不让它传到 page 层
    if (event && event.stopPropagation) {
      event.stopPropagation()
    }
  },

  handleSwipe() {
    this.showSwipeMenu = true

    const now = new Date()
    this.currentTime =
      now.getHours().toString().padStart(2, "0") +
      ":" +
      now.getMinutes().toString().padStart(2, "0")
  },

  handleLongPress() {
    // 便于调试触发菜单
    if (DEBUG) {
      if (DEBUG) console.log("[Game/UI] 触发长按")
      this.handleSwipe()
    }
  },

  returnToHome() {
    router.replace({uri: "pages/index"})
  }
}
</script>

<style>
.page {
  flex-direction: column;
  position: absolute;
  width: 100%;
  height: 100%;
}

.bg-image {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 1; /* 最底层 */
}

.ui-layer {
  flex-direction: column;
  justify-content: flex-end;
  padding: 20px;
  width: 100%;
  height: 100%;

  z-index: 10;
}

.speaker-box {
  position: absolute;
  bottom: 140px; /* 120px + 20px */
  left: 15px;
  right: 15px;

  background-color: rgba(207, 137, 248, 0.8);
  padding: 4px 12px;

  border-radius: 8px;
  margin-bottom: 5px;
  align-self: flex-start;
}

.speaker-text {
  font-size: 18px;
  color: #ffffff;
  font-weight: bold;
}

.dialogue-box {
  position: absolute;

  bottom: 20px;
  left: 15px;
  right: 15px;

  height: 120px;

  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  display: flex;
}

.scroll-view {
  width: 100%;
  height: 100%;

  /* 开启多行排列，允许内容向下延伸 */
  flex-wrap: wrap;
  padding: 12px;
}

.typewriter-text {
  /* 强制占满父宽，同时锁定左侧对齐起点 */
  width: 100%;

  color: #ffffff;
  text-align: left;
  padding: 0;
  margin: 0;
}

.menu-overlay {
  position: absolute;
  width: 100%;
  height: 100%;

  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;

  z-index: 30;
  background-color: rgba(0, 0, 0, 0.8);
}

/* 菜单容器 */
.menu-container {
  width: 80%;
  padding: 20px;
  background-color: rgba(0, 0, 0, 0.85);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  flex-direction: column;
  align-items: center;
}

.menu-title {
  color: #cf89f8;
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 15px;
