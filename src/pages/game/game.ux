<!-- 此ux有点职责过重了，后期打算模块化 -->
<template>
  <div class="page" @click="handleScreenClick" @swipe="handleSwipe" @longpress="handleLongPress">
    <image class="bg-image" src="{{ '/common/bg/' + currentBg + '.jpg' }}"></image>

    <div class="ui-layer">
      <!-- 对话框部分（说话人与打字机） -->
      <div class="speaker-box" if="{{ currentSpeaker }}">
        <text class="speaker-text">{{ currentSpeaker }}</text>
      </div>

      <div class="dialogue-box" if="{{ !isLoading }}">
        <scroll scroll-y="true" class="scroll-view" id="dialogueScroll">
          <text
            class="typewriter-text"
            style="font-size: {{ settings.textSize }}px; line-height: {{ settings.textSize * 1.3 }}px;"
          >
            {{ displayText }}
          </text>
        </scroll>
      </div>
    </div>

    <!-- 选项按钮 -->
    <div class="options-overlay" if="{{ showOptions }}">
      <div class="options-container">
        <div
          for="{{ (index, item) in currentOptions }}"
          class="option-button"
          @click="handleOptionClick(item[1], item[2])"
        >
          <text class="option-text">{{ item[0] }}</text>
        </div>
      </div>
    </div>

    <!-- 侧滑/长按菜单部分 -->
    <div class="menu-overlay" if="{{ showSwipeMenu }}">
      <!-- 暗话背景 -->
      <image
        class="bg-image"
        style="opacity: 0.4"
        src="{{ '/common/bg/' + currentBg + '.jpg' }}"
      ></image>

      <!-- 容器与按钮 -->
      <div class="menu-container" @click="stopClick">
        <text class="menu-time">{{ currentTime }}</text>

        <text class="menu-title">菜单</text>

        <div class="menu-grid">
          <div class="menu-btn" @click="saveGame">
            <text class="btn-text">保存进度</text>
          </div>
          <div class="menu-btn" @click="routeLoad">
            <text class="btn-text">读取进度</text>
          </div>
          <div class="menu-btn" @click="skipToOptions">
            <text class="btn-text">跳过到下一个选项</text>
          </div>
          <div class="menu-btn" @click="returnToHome">
            <text class="btn-text">返回主页</text>
          </div>
          <div class="menu-btn close-btn" @click="closeMenu">
            <text class="btn-text">返回游戏</text>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

