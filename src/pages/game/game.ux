  padding: 0;
  margin: 0;
}

.menu-overlay {
  position: absolute;
  width: 100%;
  height: 100%;

  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;

  z-index: 30;
  background-color: rgba(0, 0, 0, 0.8);
}

/* 菜单容器 */
.menu-container {
  width: 80%;
  padding: 20px;
  background-color: rgba(0, 0, 0, 0.85);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 20px;
